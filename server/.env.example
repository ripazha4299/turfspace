PORT=4000
JWT_SECRET=change_this_to_a_long_random_string
CLIENT_ORIGIN=http://localhost:5173
DB_PATH=./turfspace.db

# Turf images are hosted on Cloudinary -- create a free account at cloudinary.com
# and fill these in from your dashboard. Without these, image upload will fail.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Sign-In -- same Client ID as VITE_GOOGLE_CLIENT_ID on the client side
# (see client/.env.example). Without this, /api/auth/google returns a clear
# "not configured" error instead of crashing.
GOOGLE_CLIENT_ID=
