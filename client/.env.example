VITE_API_BASE_URL=http://localhost:4000/api

# Google Sign-In -- create an OAuth Client ID (type: Web application) at
# https://console.cloud.google.com/apis/credentials, add your dev/prod URLs
# under "Authorized JavaScript origins", and paste the Client ID here. Without
# this, the Google sign-in button will render but fail when clicked.
VITE_GOOGLE_CLIENT_ID=
